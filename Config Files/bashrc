# Custom Functions
function b() {
	if [ $# -eq 0 ]; then
		count=1
	else
		count="$1"
	fi

	i=0
	while [ $i -lt $count ]; do
		builtin cd '..'
	i=$((i+1))
	done
	l
}

function up() {
	if [ $# -eq 0 ]; then
		count=1
	else
		count="$1"
	fi

	i=0
	while [ $i -lt $count ]; do
		builtin cd '..'
	i=$((i+1))
	done
	l
}

function cd() {
	new_directory="$*";
	if [ $# -eq 0 ]; then
		new_directory=${HOME};
	fi;
	ls "${new_directory}" && builtin cd "${new_directory}"
	echo "${PWD}" > ~/.custom_pwd
}

function mkcdir() {
	mkdir -p -- "$1" &&
	cd "$1"
}

